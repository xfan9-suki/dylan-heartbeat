# Server
PORT=3000
NODE_ENV=production

# Upstream OpenAI-compatible API
TARGET_API_URL=https://example-provider.com/v1/chat/completions
TARGET_API_KEY=REPLACE_WITH_UPSTREAM_API_KEY
MODEL_NAME=replace-with-model-name

# Bark
BARK_KEY=REPLACE_WITH_BARK_KEY
CUSTOM_ICON_URL=

# Gateway behavior
REQUEST_BODY_LIMIT_MB=50
MULTIMODAL_MODE=text

# Cloud / worker
GATEWAY_BASE_URL=http://localhost:3000
TIME_ZONE=Asia/Shanghai

# Auth
ADMIN_USER=admin
ADMIN_PASSWORD=replace-with-strong-password
GATEWAY_API_KEY=replace-with-long-random-gateway-key
INTERNAL_SECRET=replace-with-long-random-internal-secret
DIARY_ADMIN_TOKEN=replace-with-long-random-diary-token

# Local restart command
RESTART_COMMAND="pm2 restart gateway wake-up"
